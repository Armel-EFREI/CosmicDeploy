# ─────────────────────────────────────────────────────────
# CosmicDeploy — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# NE JAMAIS committer le .env réel
# ─────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
PORT=3000

# ── Docker Hub ───────────────────────────────────────────
# Ton username Docker Hub (ex: johnDoe)
DOCKERHUB_USERNAME=your_dockerhub_username

# Token d'accès Docker Hub (pas ton mot de passe)
# Créer sur https://hub.docker.com/settings/security → "New Access Token"
DOCKERHUB_TOKEN=your_dockerhub_access_token

# Nom complet de l'image (construit automatiquement dans la pipeline)
# Format: <DOCKERHUB_USERNAME>/cosmicdeploy
DOCKER_IMAGE=your_dockerhub_username/cosmicdeploy

# Test

# ── Azure VM ─────────────────────────────────────────────
# IP publique de la VM Azure
AZURE_VM_HOST=xx.xx.xx.xx

# Utilisateur SSH de la VM (généralement azureuser)
AZURE_VM_USER=azureuser

# Mot de passe de la VM Azure
AZURE_VM_PASSWORD=your_azure_vm_password

# ─────────────────────────────────────────────────────────
# GitHub Secrets à configurer dans :
# Settings → Secrets and variables → Actions → New repository secret
#
#   DOCKERHUB_USERNAME  →  valeur de DOCKERHUB_USERNAME
#   DOCKERHUB_TOKEN     →  valeur de DOCKERHUB_TOKEN
#   AZURE_VM_HOST       →  valeur de AZURE_VM_HOST
#   AZURE_VM_USER       →  valeur de AZURE_VM_USER
#   AZURE_VM_PASSWORD     → mot de passe de la VM Azure
# ─────────────────────────────────────────────────────────
